<?xml version="1.0" encoding="UTF-8"?>
<web-app version="4.0" xmlns="http://xmlns.jcp.org/xml/ns/javaee" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd">
    <servlet>
        <servlet-name>RegisterServlet</servlet-name>
        <servlet-class>com.grievanceportal.servlet.RegisterServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>LoginServlet</servlet-name>
        <servlet-class>com.grievanceportal.servlet.LoginServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>FileGrievanceServlet</servlet-name>
        <servlet-class>com.grievanceportal.servlet.FileGrievanceServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>LogoutServlet</servlet-name>
        <servlet-class>com.grievanceportal.servlet.LogoutServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>DownloadAttachmentServlet</servlet-name>
        <servlet-class>com.grievanceportal.servlet.DownloadAttachmentServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>UpdateGrievanceServlet</servlet-name>
        <servlet-class>com.grievanceportal.servlet.UpdateGrievanceServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>DownloadOfficialAttachmentServlet</servlet-name>
        <servlet-class>com.grievanceportal.servlet.DownloadOfficialAttachmentServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>SubmitFeedbackServlet</servlet-name>
        <servlet-class>com.grievanceportal.servlet.SubmitFeedbackServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>RegisterServlet</servlet-name>
        <url-pattern>/RegisterServlet</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>LoginServlet</servlet-name>
        <url-pattern>/LoginServlet</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>FileGrievanceServlet</servlet-name>
        <url-pattern>/FileGrievanceServlet</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>LogoutServlet</servlet-name>
        <url-pattern>/LogoutServlet</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>DownloadAttachmentServlet</servlet-name>
        <url-pattern>/DownloadAttachmentServlet</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>UpdateGrievanceServlet</servlet-name>
        <url-pattern>/UpdateGrievanceServlet</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>DownloadOfficialAttachmentServlet</servlet-name>
        <url-pattern>/DownloadOfficialAttachmentServlet</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>SubmitFeedbackServlet</servlet-name>
        <url-pattern>/SubmitFeedbackServlet</url-pattern>
    </servlet-mapping>
    <session-config>
        <session-timeout>
            30
        </session-timeout>
    </session-config>
</web-app>
